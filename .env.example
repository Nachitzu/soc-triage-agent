# Anthropic API key. Required. Never commit the real value.
ANTHROPIC_API_KEY=sk-ant-...

# AbuseIPDB API key. Powers lookup_ip_reputation. Without it the tool returns
# an "unavailable" status and triage proceeds without reputation data.
ABUSEIPDB_API_KEY=

# Path to the local SQLite store (alert history + IP reputation cache).
# Defaults to data/triage.db, which is git-ignored.
TRIAGE_DB=data/triage.db

# Model used for triage.
#   claude-sonnet-4-6  -> reasoning-heavy triage (default)
#   claude-haiku-4-5   -> high-volume / cost-optimized batch runs
TRIAGE_MODEL=claude-sonnet-4-6

# Extended thinking mode: auto | adaptive | off
#   auto     -> enable adaptive thinking only on models that support it
#   adaptive -> force adaptive thinking (rejected by claude-haiku-4-5)
#   off      -> never send a thinking parameter
TRIAGE_THINKING=auto

# Reasoning depth (output_config.effort): low | medium | high | max
# Unset -> the API default (high). "medium" or "low" cut thinking-token spend
# without turning reasoning off — the recommended first knob for cheap batch
# runs. Ignored for claude-haiku-4-5, which rejects the parameter.
TRIAGE_EFFORT=
